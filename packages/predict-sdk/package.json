{
  "name": "@nanawise/predict-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for DeepBook Predict on Sui — typed server reads, on-chain reads, and PTB builders for binary/range options, the PLP vault, and on-chain agent wallets.",
  "license": "MIT",
  "keywords": ["sui", "deepbook", "predict", "prediction-market", "options", "defi"],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@mysten/bcs": "^2.1.0",
    "@mysten/sui": "^2.19.0",
    "@nanawise/shared": "workspace:^",
    "zod": "^4.4.3"
  }
}
