{
  "name": "nanawise",
  "version": "0.0.0",
  "private": true,
  "description": "Nanawise — chat-first DeepBook Predict trading on Sui (zkLogin, agent wallets, vault)",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "spike": "tsx scripts/spike-mint.ts",
    "key:new": "tsx scripts/new-key.ts",
    "loadtest": "tsx scripts/load-test.ts"
  },
  "devDependencies": {
    "@mysten/sui": "^2.19.0",
    "@nanawise/predict-sdk": "workspace:*",
    "@nanawise/shared": "workspace:*",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "playwright": "1.61.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
